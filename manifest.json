{
  "manifest_version": 3,
  "name": "Stride",
  "version": "1.0.0",
  "description": "A focused daily interview prep system that helps you stay consistent",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "options_page": "options.html",
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
